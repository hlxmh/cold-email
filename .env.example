# .env.example — Copy this file to .env and fill in your values.
# The app reads these automatically at startup (via python-dotenv).

# ----- Gmail sender account -----
# Use an App Password, NOT your regular Google password:
# Google Account → Security → 2-Step Verification → App passwords
# https://myaccount.google.com/apppasswords
GMAIL_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ----- Optional defaults -----
# Email subject (can also be passed with --subject)
EMAIL_SUBJECT=

# Website to scrape (can also be passed with --website)
TARGET_WEBSITE=
